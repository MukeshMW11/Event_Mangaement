{
  "compilerOptions": {
    // Layout
    "rootDir": ".",
    "outDir": "./dist",

    // Environment
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2020",
    "lib": ["ES2020"],
    "types": ["node"],          

    // Interop
    "esModuleInterop": true,
    "resolveJsonModule": true,

    // Output
    "sourceMap": true,
    "declaration": true,

    // Strict
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "moduleDetection": "force",
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}